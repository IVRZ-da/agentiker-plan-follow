FROM node:20-bookworm

# Python + pip installieren (Debian Bookworm, kein ensurepip)
RUN apt-get update -qq && \
    apt-get install -y -qq python3 python3-pip python3-yaml --no-install-recommends && \
    pip3 install pytest --break-system-packages && \
    rm -rf /var/lib/apt/lists/*

# Verify
RUN python3 --version && pip3 --version && python3 -c "import pytest; print('pytest', pytest.__version__)"
